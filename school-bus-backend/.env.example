# PostgreSQL
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/school_bus?schema=public"

# Redis (sessions, OTP, live bus location cache)
REDIS_URL="redis://default:dRBnwaALOTcUcveuLsgturpooZRlZfPG@interchange.proxy.rlwy.net:11104"

# Kafka (tracking event stream; omit or set KAFKA_DISABLED=1 for local without Kafka)
KAFKA_BROKERS="INTERNAL://kafka.railway.internal:29092"
KAFKA_CLIENT_ID="school-bus-backend"
KAFKA_GROUP_ID="school-bus-tracking-consumer"
KAFKA_TRACKING_TOPIC="tracking.events"
KAFKA_DISABLED="0"

# JWT
JWT_ACCESS_SECRET="change-me-access-min-32-chars-long-secret"
JWT_REFRESH_SECRET="change-me-refresh-min-32-chars-long-secret"
JWT_ACCESS_EXPIRES_SEC="900"
JWT_REFRESH_EXPIRES_SEC="604800"


KAFKA_ADVERTISED_LISTENERS="INTERNAL://kafka.railway.internal:29092"
KAFKA_INTER_BROKER_LISTENER_NAME="INTERNAL"
KAFKA_LISTENER_SECURITY_PROTOCOL_MAP="INTERNAL:PLAINTEXT"
KAFKA_ZOOKEEPER_CONNECT="zookeeper.railway.internal:2181"
PORT="29092"

# OTP (6-digit; in dev use OTP_DEV_CODE for predictable login)
OTP_TTL_SECONDS="300"
OTP_DEV_CODE=""

# App
PORT="3000"
NODE_ENV="development"
